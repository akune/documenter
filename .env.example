# ===========================================
# Document Processor Configuration
# ===========================================
# Copy this file to .env and adjust values

# ----- Logging -----
LOG_LEVEL=INFO

# ----- OCR Settings -----
# Language codes for Tesseract (use + for multiple, e.g., deu+eng)
OCR_LANGUAGE=deu+eng

# Enable page deskewing
OCR_DESKEW=true

# Enable page cleaning (noise removal)
OCR_CLEAN=true

# Enable automatic page rotation
OCR_ROTATE_PAGES=true

# Threshold for automatic page rotation (0.0-1.0, higher = stricter)
OCR_ROTATE_PAGES_THRESHOLD=1.0

# ----- Blank Page Detection -----
# Enable blank page removal
BLANK_PAGE_REMOVAL=true

# Threshold for blank detection (0.0-1.0, higher = stricter)
# 0.99 means page must be 99% white to be considered blank
BLANK_PAGE_THRESHOLD=0.99

# ----- QR Code Document Splitting -----
# Enable document splitting based on QR code markers
SPLIT_QR_ENABLED=true

# Content of the QR code that triggers a document split
# Each page with this QR code starts a new document
SPLIT_QR_CONTENT=[dmsqrnd]

# ----- Nextcloud Settings -----
# Enable Nextcloud upload
NEXTCLOUD_ENABLED=true

# Nextcloud server URL (without trailing slash)
NEXTCLOUD_URL=https://cloud.example.com

# Nextcloud username
NEXTCLOUD_USER=your_username

# Nextcloud app password (generate in Settings -> Security -> App passwords)
NEXTCLOUD_PASSWORD=your_app_password

# Target directory in Nextcloud (documents will be placed in YYYY-MM subfolders)
NEXTCLOUD_TARGET_DIR=/Documents/Scans

# ----- Paperless-ngx Settings -----
# Enable Paperless-ngx upload
PAPERLESS_ENABLED=true

# Paperless-ngx server URL (without trailing slash)
PAPERLESS_URL=https://paperless.example.com

# Paperless-ngx API token (generate in Admin -> Tokens)
PAPERLESS_API_TOKEN=your_api_token

# Default tags to apply (comma-separated)
# YYYY-MM tag is automatically added based on document date
PAPERLESS_DEFAULT_TAGS=Inbox

# Custom fields (JSON format)
# Available variables:
#   ${directory_path} - Relative directory path (import) or YYYY-MM (processing)
#   ${year_month}     - Year and month from document date (YYYY-MM)
#   ${filename}       - Document filename
#   ${title}          - Document title
# Example: Set "Physical Location" field to the relative directory path
# PAPERLESS_CUSTOM_FIELDS={"Physical Location": "${directory_path}"}
PAPERLESS_CUSTOM_FIELDS=

# ----- Processing Settings -----
# Delete source file after successful processing
DELETE_SOURCE=true

# Seconds to wait for file to stabilize before processing
FILE_STABILITY_SECONDS=5

# Interval for file stability checks
POLL_INTERVAL=1.0

# ----- Output Directory Settings -----
# Enable writing processed files to output directory
OUTPUT_DIR_ENABLED=false

# Output directory path
OUTPUT_DIR=/output

# Use YYYY-MM subfolders in output directory
OUTPUT_DIR_USE_SUBFOLDERS=true
